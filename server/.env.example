# Copy this file to .env and fill in real values. Never commit .env.

# Sarvam AI — https://dashboard.sarvam.ai. NOT free: ~Rs.100 trial credit on
# signup, then STT Rs.30/hour and TTS Rs.15/10K chars, billed per use.
SARVAM_API_KEY=

# Which provider runs each leg of the cascade.
#   STT_PROVIDER  sarvam | whisper   (default sarvam)
#   TTS_PROVIDER  sarvam | kokoro    (default sarvam)
#   LLM_PROVIDER  google | sarvam    (default google — see below)
# LLM_PROVIDER stays on google deliberately: sarvam-30b emitted zero save_field
# tool calls over a 5-turn intake and produced an empty record, where gemini
# saved 4/5. Prove it changed with smoke/test_sarvam_tools.py before flipping.
# To fall back to the fully-local speech stack: STT_PROVIDER=whisper TTS_PROVIDER=kokoro

# Google AI Studio key (free tier) — https://aistudio.google.com/apikey
# Required at the default LLM_PROVIDER=google.
GOOGLE_API_KEY=

# Supabase project — Settings > API in your Supabase dashboard
SUPABASE_URL=
# service_role key — server-only, never expose to the browser/React app
SUPABASE_SERVICE_KEY=
